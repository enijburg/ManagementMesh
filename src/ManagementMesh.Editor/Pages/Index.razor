@page "/"
@using System.Text.Json
@using ManagementMesh.Editor.Models

<PageTitle>VeriSM Management Mesh Editor</PageTitle>

<h1>VeriSM Management Mesh Editor</h1>
<p>Select a color, then drag from top/left handles to set how far each thread extends into the mesh.</p>

<section class="panel">
    <h2>Service Context (Define)</h2>
    <div class="context-grid">
        <label>Product / Service <input @bind="Document.ProductOrService" /></label>
        <label>Value objective <input @bind="Document.ValueObjective" /></label>
        <label>Governance constraints <input @bind="Document.GovernanceConstraints" /></label>
        <label>Consumer needs <input @bind="Document.ConsumerNeeds" /></label>
    </div>
</section>

<section class="panel">
    <h2>Interactive Management Mesh</h2>
    <div class="toolbar mesh-tools">
        <label class="color-picker">Thread color <input type="color" @bind="SelectedColor" /></label>
        <button class="secondary" @onclick="ResetColors">Reset colors</button>
    </div>

    <div class="mesh-layout">
        <div class="top-title">Resources</div>
        <div class="left-title">Environment</div>
        <div class="right-title">Emerging Technologies</div>
        <div class="bottom-title">Management Practices</div>

        <div class="top-labels">
            @foreach (var label in Resources)
            {
                <div class="mesh-label">@label</div>
            }
        </div>

        <div class="left-labels" style="grid-template-rows: repeat(@HorizontalCount, 1fr);">
            @foreach (var label in Environment)
            {
                <div class="mesh-label">@label</div>
            }
        </div>

        <div class="right-labels" style="grid-template-rows: repeat(@HorizontalCount, 1fr);">
            @foreach (var label in EmergingTechnologies)
            {
                <div class="mesh-label">@label</div>
            }
        </div>

        <div class="bottom-labels">
            @foreach (var label in ManagementPractices)
            {
                <div class="mesh-label">@label</div>
            }
        </div>

        <div class="mesh-canvas">
            <svg viewBox="0 0 @SvgSize @SvgSize" class="mesh-svg"
                 @onpointerup="EndDrag" @onpointerleave="EndDrag" @onpointermove="UpdateDrag">
                <defs>
                    <linearGradient id="threadShade" x1="0" y1="0" x2="1" y2="0">
                        <stop offset="0%" stop-color="#ffffff" stop-opacity="0.55" />
                        <stop offset="45%" stop-color="#ffffff" stop-opacity="0.1" />
                        <stop offset="55%" stop-color="#000000" stop-opacity="0.08" />
                        <stop offset="100%" stop-color="#000000" stop-opacity="0.15" />
                    </linearGradient>
                </defs>

                @for (var row = ActiveRowStart; row <= ActiveRowEnd; row++)
                {
                    var y = Padding + row * StepY;
                    <line x1="@MeshStartX" y1="@y" x2="@MeshEndX" y2="@y" stroke="#dde1e8" stroke-width="@ThreadThickness" stroke-linecap="round" />
                }

                @for (var col = ActiveColStart; col <= ActiveColEnd; col++)
                {
                    var x = Padding + col * StepX;
                    <line x1="@x" y1="@MeshStartY" x2="@x" y2="@MeshEndY" stroke="#dde1e8" stroke-width="@ThreadThickness" stroke-linecap="round" />
                }

                @for (var col = ActiveColStart; col <= ActiveColEnd; col++)
                {
                    var x = Padding + col * StepX;
                    var key = ColumnKey(col);
                    var stopRow = Document.VerticalThreadStops.GetValueOrDefault(key, ActiveRowStart);
                    var stopY = Padding + stopRow * StepY;
                    <line x1="@x" y1="@MeshStartY" x2="@x" y2="@stopY" stroke="@ColorForVertical(key)" stroke-width="@ThreadThickness" stroke-linecap="round" />
                }

                @for (var row = ActiveRowStart; row <= ActiveRowEnd; row++)
                {
                    var y = Padding + row * StepY;
                    var key = RowKey(row);
                    var stopCol = Document.HorizontalThreadStops.GetValueOrDefault(key, ActiveColStart);
                    var stopX = Padding + stopCol * StepX;
                    <line x1="@MeshStartX" y1="@y" x2="@stopX" y2="@y" stroke="@ColorForHorizontal(key)" stroke-width="@ThreadThickness" stroke-linecap="round" />
                }

                @for (var row = ActiveRowStart; row <= ActiveRowEnd; row++)
                {
                    for (var col = ActiveColStart; col <= ActiveColEnd; col++)
                    {
                        var x = Padding + col * StepX;
                        var y = Padding + row * StepY;
                        var verticalKey = ColumnKey(col);
                        var horizontalKey = RowKey(row);
                        var verticalActive = Document.VerticalThreadStops[verticalKey] >= row;
                        var horizontalActive = Document.HorizontalThreadStops[horizontalKey] >= col;
                        var isVerticalOver = (row + col) % 2 == 0;

                        if (verticalActive && isVerticalOver)
                        {
                            <rect x="@(x - ThreadThickness / 2.0)" y="@(y - WeavePatch / 2.0)" width="@ThreadThickness" height="@WeavePatch"
                                  rx="@(ThreadThickness / 2.5)" fill="@ColorForVertical(verticalKey)" />
                        }

                        if (horizontalActive && !isVerticalOver)
                        {
                            <rect x="@(x - WeavePatch / 2.0)" y="@(y - ThreadThickness / 2.0)" width="@WeavePatch" height="@ThreadThickness"
                                  rx="@(ThreadThickness / 2.5)" fill="@ColorForHorizontal(horizontalKey)" />
                        }
                    }
                }

                @for (var col = ActiveColStart; col <= ActiveColEnd; col++)
                {
                    var x = Padding + col * StepX;
                    <circle cx="@x" cy="@(MeshStartY - HandleOffset)" r="@HandleRadius" fill="#3b82f6"
                            @onpointerdown="() => BeginDrag(ThreadAxis.Vertical, col)" />
                }

                @for (var row = ActiveRowStart; row <= ActiveRowEnd; row++)
                {
                    var y = Padding + row * StepY;
                    <circle cx="@(MeshStartX - HandleOffset)" cy="@y" r="@HandleRadius" fill="#3b82f6"
                            @onpointerdown="() => BeginDrag(ThreadAxis.Horizontal, row)" />
                }
            </svg>
        </div>
    </div>
</section>

<section class="panel">
    <h2>Share / Persist</h2>
    <div class="toolbar">
        <button @onclick="ExportJson">Export JSON</button>
        <button class="secondary" @onclick="LoadSample">Load sample</button>
        <button class="ghost" @onclick="ImportJson">Import JSON</button>
    </div>
    <textarea @bind="Serialized"></textarea>
</section>

@code {
    private static readonly string[] Resources =
    ["People", "Supplier", "Budget", "Assets", "Time", "Knowledge", "Others"];

    private static readonly string[] ManagementPractices =
    ["ITIL/COBIT/CMMI-SVC", "ISO/IEC 20000/27000/38500", "DevOps/Agile/Lean", "Project & Portfolio Management", "SIAM", "Security Practices", "Others"];

    private static readonly string[] Environment =
    ["Others", "Organizational Culture", "Competition", "Legislation", "Partners", "Service Stabilizers", "Risk Controls", "Operating Model", "Governance", "Compliance"];

    private static readonly string[] EmergingTechnologies =
    ["Containers", "AI", "IoT", "BYOD", "Big Data", "Serverless Computing", "Cloud", "Automation", "Virtualization", "Others"];

    private const int SvgSize = 640;
    private const int Padding = 34;
    private const double ThreadThickness = 11;
    private const double WeavePatch = 19;
    private const double HandleRadius = 8;
    private const double HandleOffset = 16;

    private static int VerticalCount => Math.Max(Resources.Length, ManagementPractices.Length);
    private static int HorizontalCount => Math.Max(Environment.Length, EmergingTechnologies.Length);
    private static int ActiveColStart => 1;
    private static int ActiveColEnd => VerticalCount - 2;
    private static int ActiveRowStart => 1;
    private static int ActiveRowEnd => HorizontalCount - 2;

    private static double StepX => (SvgSize - Padding * 2.0) / (VerticalCount - 1);
    private static double StepY => (SvgSize - Padding * 2.0) / (HorizontalCount - 1);
    private static double MeshStartX => Padding + ActiveColStart * StepX;
    private static double MeshEndX => Padding + ActiveColEnd * StepX;
    private static double MeshStartY => Padding + ActiveRowStart * StepY;
    private static double MeshEndY => Padding + ActiveRowEnd * StepY;

    private ManagementMeshDocument Document { get; set; } = new();
    private string Serialized { get; set; } = string.Empty;
    private string SelectedColor { get; set; } = "#e35a5a";

    private ThreadAxis? DragAxis { get; set; }
    private int DragIndex { get; set; } = -1;

    protected override void OnInitialized()
    {
        Document = SeedDocument();
        ExportJson();
    }

    private static ManagementMeshDocument SeedDocument()
    {
        var doc = new ManagementMeshDocument();

        foreach (var col in Enumerable.Range(0, VerticalCount))
        {
            var key = ColumnKey(col);
            doc.VerticalThreadColors[key] = "#d9dce2";
            doc.VerticalThreadStops[key] = ActiveRowStart;
        }

        foreach (var row in Enumerable.Range(0, HorizontalCount))
        {
            var key = RowKey(row);
            doc.HorizontalThreadColors[key] = "#d9dce2";
            doc.HorizontalThreadStops[key] = ActiveColStart;
        }

        return doc;
    }

    private static string RowKey(int row) => $"row-{row}";
    private static string ColumnKey(int col) => $"col-{col}";

    private string ColorForHorizontal(string rowKey) => Document.HorizontalThreadColors.GetValueOrDefault(rowKey, "#d9dce2");
    private string ColorForVertical(string columnKey) => Document.VerticalThreadColors.GetValueOrDefault(columnKey, "#d9dce2");

    private void BeginDrag(ThreadAxis axis, int index)
    {
        DragAxis = axis;
        DragIndex = index;

        if (axis == ThreadAxis.Vertical)
        {
            Document.VerticalThreadColors[ColumnKey(index)] = SelectedColor;
        }
        else
        {
            Document.HorizontalThreadColors[RowKey(index)] = SelectedColor;
        }
    }

    private void UpdateDrag(Microsoft.AspNetCore.Components.Web.PointerEventArgs args)
    {
        if (DragAxis is null || DragIndex < 0)
        {
            return;
        }

        if (DragAxis == ThreadAxis.Vertical)
        {
            var row = Clamp((int)Math.Round((args.OffsetY - Padding) / StepY), ActiveRowStart, ActiveRowEnd);
            Document.VerticalThreadStops[ColumnKey(DragIndex)] = row;
        }
        else
        {
            var col = Clamp((int)Math.Round((args.OffsetX - Padding) / StepX), ActiveColStart, ActiveColEnd);
            Document.HorizontalThreadStops[RowKey(DragIndex)] = col;
        }

        ExportJson();
    }

    private void EndDrag()
    {
        DragAxis = null;
        DragIndex = -1;
    }

    private static int Clamp(int value, int min, int max) => value < min ? min : value > max ? max : value;

    private void ResetColors()
    {
        Document = SeedDocument();
        ExportJson();
    }

    private void ExportJson()
    {
        Serialized = JsonSerializer.Serialize(Document, new JsonSerializerOptions { WriteIndented = true });
    }

    private void ImportJson()
    {
        var imported = JsonSerializer.Deserialize<ManagementMeshDocument>(Serialized);
        if (imported is not null)
        {
            Document = imported;
        }
    }

    private void LoadSample()
    {
        Document = SeedDocument();
        Document.ProductOrService = "Digital Claims Platform";
        Document.ValueObjective = "Reduce claim cycle time by 40%";
        Document.ConsumerNeeds = "Fast updates, transparent status";
        Document.GovernanceConstraints = "Privacy and auditability";

        foreach (var col in new[] { 2, 3, 4, 5 })
        {
            Document.VerticalThreadColors[ColumnKey(col)] = "#e35a5a";
            Document.VerticalThreadStops[ColumnKey(col)] = ActiveRowEnd;
        }

        Document.HorizontalThreadColors[RowKey(3)] = "#e35a5a";
        Document.HorizontalThreadStops[RowKey(3)] = ActiveColEnd;

        ExportJson();
    }
}
