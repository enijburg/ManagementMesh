@page "/"
@using System.Text.Json
@using ManagementMesh.Editor.Models

<PageTitle>VeriSM Management Mesh Editor</PageTitle>

<h1>VeriSM Management Mesh Editor</h1>
<p>Use the color picker, then hover and click individual mesh threads to color the woven map.</p>

<section class="panel">
    <h2>Service Context (Define)</h2>
    <div class="context-grid">
        <label>Product / Service <input @bind="Document.ProductOrService" /></label>
        <label>Value objective <input @bind="Document.ValueObjective" /></label>
        <label>Governance constraints <input @bind="Document.GovernanceConstraints" /></label>
        <label>Consumer needs <input @bind="Document.ConsumerNeeds" /></label>
    </div>
</section>

<section class="panel">
    <h2>Interactive Management Mesh</h2>
    <div class="toolbar mesh-tools">
        <label class="color-picker">Thread color <input type="color" @bind="SelectedColor" /></label>
        <button class="secondary" @onclick="ResetColors">Reset colors</button>
    </div>

    <div class="mesh-layout">
        <div class="top-title">Resources</div>
        <div class="left-title">Environment</div>
        <div class="right-title">Emerging Technologies</div>
        <div class="bottom-title">Management Practices</div>

        <div class="top-labels">
            @foreach (var label in Resources)
            {
                <div class="mesh-label">@label</div>
            }
        </div>

        <div class="left-labels">
            @foreach (var label in Environment)
            {
                <div class="mesh-label">@label</div>
            }
        </div>

        <div class="right-labels">
            @foreach (var label in EmergingTechnologies)
            {
                <div class="mesh-label">@label</div>
            }
        </div>

        <div class="bottom-labels">
            @foreach (var label in ManagementPractices)
            {
                <div class="mesh-label">@label</div>
            }
        </div>

        <div class="mesh-canvas" @onmouseleave="ClearHover">
            <svg viewBox="0 0 @SvgSize @SvgSize" class="mesh-svg" role="img" aria-label="Woven management mesh">
                <defs>
                    <linearGradient id="threadShade" x1="0" y1="0" x2="1" y2="0">
                        <stop offset="0%" stop-color="#ffffff" stop-opacity="0.75" />
                        <stop offset="45%" stop-color="#ffffff" stop-opacity="0.15" />
                        <stop offset="55%" stop-color="#000000" stop-opacity="0.10" />
                        <stop offset="100%" stop-color="#000000" stop-opacity="0.20" />
                    </linearGradient>
                </defs>

                @for (var row = 0; row < HorizontalCount; row++)
                {
                    var y = Padding + row * StepY;
                    var rowKey = RowKey(row);
                    var rowColor = ColorForHorizontal(rowKey);
                    var hovered = HoverAxis == ThreadAxis.Horizontal && HoverIndex == row;

                    <line x1="@Padding" y1="@y" x2="@(SvgSize - Padding)" y2="@y"
                          stroke="@rowColor" stroke-width="@ThreadThickness" stroke-linecap="round"
                          opacity="@(hovered ? "1" : "0.92")"
                          @onmouseover="() => SetHover(ThreadAxis.Horizontal, row)"
                          @onclick="() => ApplyColor(ThreadAxis.Horizontal, rowKey)"/>

                    <line x1="@Padding" y1="@y" x2="@(SvgSize - Padding)" y2="@y"
                          stroke="url(#threadShade)" stroke-width="@ThreadThickness" stroke-linecap="round"
                          opacity="0.35" pointer-events="none"/>
                }

                @for (var col = 0; col < VerticalCount; col++)
                {
                    var x = Padding + col * StepX;
                    var colKey = ColumnKey(col);
                    var colColor = ColorForVertical(colKey);
                    var hovered = HoverAxis == ThreadAxis.Vertical && HoverIndex == col;

                    <line x1="@x" y1="@Padding" x2="@x" y2="@(SvgSize - Padding)"
                          stroke="@colColor" stroke-width="@ThreadThickness" stroke-linecap="round"
                          opacity="@(hovered ? "1" : "0.92")"
                          @onmouseover="() => SetHover(ThreadAxis.Vertical, col)"
                          @onclick="() => ApplyColor(ThreadAxis.Vertical, colKey)"/>

                    <line x1="@x" y1="@Padding" x2="@x" y2="@(SvgSize - Padding)"
                          stroke="url(#threadShade)" stroke-width="@ThreadThickness" stroke-linecap="round"
                          opacity="0.35" pointer-events="none"/>
                }

                @for (var row = 0; row < HorizontalCount; row++)
                {
                    for (var col = 0; col < VerticalCount; col++)
                    {
                        var x = Padding + col * StepX;
                        var y = Padding + row * StepY;
                        var isVerticalOver = (row + col) % 2 == 0;

                        if (isVerticalOver)
                        {
                            <rect x="@(x - ThreadThickness / 2.0)" y="@(y - WeavePatch / 2.0)" width="@ThreadThickness" height="@WeavePatch"
                                  rx="@(ThreadThickness / 2.6)" fill="@ColorForVertical(ColumnKey(col))" pointer-events="none" />
                            <rect x="@(x - ThreadThickness / 2.0)" y="@(y - WeavePatch / 2.0)" width="@ThreadThickness" height="@WeavePatch"
                                  rx="@(ThreadThickness / 2.6)" fill="url(#threadShade)" opacity="0.35" pointer-events="none" />
                        }
                        else
                        {
                            <rect x="@(x - WeavePatch / 2.0)" y="@(y - ThreadThickness / 2.0)" width="@WeavePatch" height="@ThreadThickness"
                                  rx="@(ThreadThickness / 2.6)" fill="@ColorForHorizontal(RowKey(row))" pointer-events="none" />
                            <rect x="@(x - WeavePatch / 2.0)" y="@(y - ThreadThickness / 2.0)" width="@WeavePatch" height="@ThreadThickness"
                                  rx="@(ThreadThickness / 2.6)" fill="url(#threadShade)" opacity="0.35" pointer-events="none" />
                        }
                    }
                }
            </svg>
        </div>
    </div>
</section>

<section class="panel">
    <h2>Share / Persist</h2>
    <div class="toolbar">
        <button @onclick="ExportJson">Export JSON</button>
        <button class="secondary" @onclick="LoadSample">Load sample</button>
        <button class="ghost" @onclick="ImportJson">Import JSON</button>
    </div>
    <textarea @bind="Serialized"></textarea>
</section>

@code {
    private static readonly string[] Resources =
    ["People", "Supplier", "Budget", "Assets", "Time", "Knowledge", "Others"];

    private static readonly string[] ManagementPractices =
    ["ITIL/COBIT/CMMI-SVC", "ISO/IEC 20000/27000/38500", "DevOps/Agile/Lean", "Project & Portfolio Management", "SIAM", "Security Practices", "Others"];

    private static readonly string[] Environment =
    ["Others", "Organizational Culture", "Competition", "Legislation", "Partners", "Service Stabilizers", "Risk Controls", "Operating Model", "Governance", "Compliance"];

    private static readonly string[] EmergingTechnologies =
    ["Containers", "AI", "IoT", "BYOD", "Big Data", "Serverless Computing", "Cloud", "Automation", "Virtualization", "Others"];

    private const int SvgSize = 640;
    private const int Padding = 34;
    private const double ThreadThickness = 12;
    private const double WeavePatch = 20;

    private static int VerticalCount => Math.Max(Resources.Length, ManagementPractices.Length);
    private static int HorizontalCount => Math.Max(Environment.Length, EmergingTechnologies.Length);
    private static double StepX => (SvgSize - Padding * 2.0) / (VerticalCount - 1);
    private static double StepY => (SvgSize - Padding * 2.0) / (HorizontalCount - 1);

    private ManagementMeshDocument Document { get; set; } = new();
    private string Serialized { get; set; } = string.Empty;
    private string SelectedColor { get; set; } = "#5b8bd9";
    private ThreadAxis? HoverAxis { get; set; }
    private int HoverIndex { get; set; } = -1;

    protected override void OnInitialized()
    {
        Document = SeedDocument();
        ExportJson();
    }

    private static ManagementMeshDocument SeedDocument()
    {
        var doc = new ManagementMeshDocument();

        foreach (var key in Enumerable.Range(0, VerticalCount).Select(ColumnKey))
        {
            doc.VerticalThreadColors[key] = "#d5d7db";
        }

        foreach (var key in Enumerable.Range(0, HorizontalCount).Select(RowKey))
        {
            doc.HorizontalThreadColors[key] = "#d5d7db";
        }

        return doc;
    }

    private static string RowKey(int row) => $"row-{row}";
    private static string ColumnKey(int col) => $"col-{col}";

    private string ColorForHorizontal(string rowKey) =>
        Document.HorizontalThreadColors.GetValueOrDefault(rowKey, "#d5d7db");

    private string ColorForVertical(string columnKey) =>
        Document.VerticalThreadColors.GetValueOrDefault(columnKey, "#d5d7db");

    private void ApplyColor(ThreadAxis axis, string key)
    {
        if (axis == ThreadAxis.Horizontal)
        {
            Document.HorizontalThreadColors[key] = SelectedColor;
        }
        else
        {
            Document.VerticalThreadColors[key] = SelectedColor;
        }

        ExportJson();
    }

    private void SetHover(ThreadAxis axis, int index)
    {
        HoverAxis = axis;
        HoverIndex = index;
    }

    private void ClearHover()
    {
        HoverAxis = null;
        HoverIndex = -1;
    }

    private void ResetColors()
    {
        Document = SeedDocument();
        ExportJson();
    }

    private void ExportJson()
    {
        Serialized = JsonSerializer.Serialize(Document, new JsonSerializerOptions { WriteIndented = true });
    }

    private void ImportJson()
    {
        var imported = JsonSerializer.Deserialize<ManagementMeshDocument>(Serialized);
        if (imported is not null)
        {
            Document = imported;
        }
    }

    private void LoadSample()
    {
        Document = SeedDocument();
        Document.ProductOrService = "Digital Claims Platform";
        Document.ValueObjective = "Reduce claim cycle time by 40%";
        Document.ConsumerNeeds = "Fast updates, transparent status";
        Document.GovernanceConstraints = "Privacy and auditability";

        Document.VerticalThreadColors[ColumnKey(0)] = "#3b82f6";
        Document.VerticalThreadColors[ColumnKey(2)] = "#22c55e";
        Document.VerticalThreadColors[ColumnKey(4)] = "#a855f7";
        Document.HorizontalThreadColors[RowKey(1)] = "#f59e0b";
        Document.HorizontalThreadColors[RowKey(5)] = "#ef4444";
        Document.HorizontalThreadColors[RowKey(7)] = "#14b8a6";

        ExportJson();
    }
}
